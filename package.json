{
  "name": "risebyeden",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:with-db": "bash scripts/dev-with-db.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib prisma --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cache-hooks": "node scripts/test-cache-hooks.js",
    "test:ci": "npm run -s test && npm run -s test:cache-hooks",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "db:monitor": "tsx scripts/db-monitor.ts",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.38.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.69",
    "@visx/curve": "^3.12.0",
    "@visx/event": "^3.12.0",
    "@visx/gradient": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.4",
    "next": "^15.1.4",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^4.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.1.4",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
